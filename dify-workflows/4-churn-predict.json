          "data": {
            "code": "def main(days_since_last_visit: int, total_spent: float) -> dict:\n    from datetime import datetime\n    \n    # 流失风险评分 (0-100)\n    risk_score = min(100, int(days_since_last_visit * 1.5))\n    if days_since_last_visit > 60:\n        risk_score = min(100, risk_score + 20)\n    elif days_since_last_visit > 30:\n        risk_score = min(100, risk_score + 10)\n    \n    # CLV 粗估 (简化模型)\n    clv_estimate = total_spent * (365 / max(1, days_since_last_visit))\n    \n    # 风险等级判定\n    if risk_score >= 70:\n        risk_level = \"high\"\n    elif risk_score >= 40:\n        risk_level = \"medium\"\n    else:\n        risk_level = \"low\"\n    \n    return {\n        \"risk_score\": risk_score,\n        \"risk_level\": risk_level,\n        \"clv_estimate\": round(clv_estimate, 2),\n        \"days_since_last\": days_since_last_visit\n    }\n",
            "code_language": "python3",
